{
  "name": "skinnycoder",
  "version": "0.1.0",
  "description": "A lean amber-terminal coding CLI that delegates thinking to Codex and keeps local edits explicit.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/brainit-consulting/skinnycoder.git"
  },
  "bin": {
    "skinnycoder": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "prepack": "npm run build",
    "test:smoke": "npm run build && node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "diff": "^8.0.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
